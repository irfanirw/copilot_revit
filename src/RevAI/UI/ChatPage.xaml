<Page x:Class="RevAI.UI.ChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:RevAI.UI"
      Background="#1E1E2E"
      Foreground="#CDD6F4">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InverseBool"/>

        <!-- Scrollbar styling -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Chat bubble base style -->
        <Style x:Key="ChatBubbleBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="MaxWidth" Value="400"/>
        </Style>

        <!-- User message bubble -->
        <Style x:Key="UserBubble" TargetType="Border" BasedOn="{StaticResource ChatBubbleBase}">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- Assistant message bubble -->
        <Style x:Key="AssistantBubble" TargetType="Border" BasedOn="{StaticResource ChatBubbleBase}">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- System/status message -->
        <Style x:Key="SystemBubble" TargetType="Border" BasedOn="{StaticResource ChatBubbleBase}">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.8"/>
        </Style>

        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B4D0FB"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#45475A"/>
                    <Setter Property="Foreground" Value="#6C7086"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxHeight" Value="120"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🤖 RevAI" FontSize="18" FontWeight="Bold" Foreground="#A6E3A1"/>
                    <TextBlock Text="AI-Powered Revit Assistant" FontSize="11" Foreground="#6C7086" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="⚙️ Settings" 
                        Style="{StaticResource PrimaryButton}"
                        Background="#45475A" Foreground="#CDD6F4"
                        Margin="0,0,8,0"
                        Click="Settings_Click"/>

                <Button Grid.Column="2" Content="🗑️ Clear"
                        Style="{StaticResource PrimaryButton}"
                        Background="#45475A" Foreground="#CDD6F4"
                        Click="Clear_Click"/>
            </Grid>
        </Border>

        <!-- Settings Panel (collapsible) -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#181825" 
                Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="10"
                Margin="0,50,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="AI Provider Settings" FontSize="18" FontWeight="Bold" Foreground="#A6E3A1" Margin="0,0,0,16"/>

                <TextBlock Text="AI Provider:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                <ComboBox x:Name="ProviderComboBox"
                          Background="#313244" Foreground="#CDD6F4"
                          BorderBrush="#45475A" Padding="8,6"
                          Margin="0,0,0,16"
                          SelectionChanged="ProviderComboBox_SelectionChanged">
                    <ComboBoxItem Content="M365 Copilot (Azure OpenAI)" Tag="Copilot" IsSelected="True"/>
                    <ComboBoxItem Content="OpenAI ChatGPT" Tag="OpenAI"/>
                    <ComboBoxItem Content="Anthropic Claude" Tag="Claude"/>
                    <ComboBoxItem Content="Ollama (Offline)" Tag="Ollama"/>
                </ComboBox>

                <!-- Copilot (Azure OpenAI) Settings -->
                <StackPanel x:Name="CopilotSettingsPanel">
                    <TextBlock Text="Azure OpenAI Endpoint:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <TextBox x:Name="EndpointBox" 
                             Background="#313244" Foreground="#CDD6F4"
                             BorderBrush="#45475A" Padding="8,6"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="e.g. https://your-resource.openai.azure.com" 
                               FontSize="11" Foreground="#6C7086" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Text="Deployment Name:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <TextBox x:Name="DeploymentBox" 
                             Background="#313244" Foreground="#CDD6F4"
                             BorderBrush="#45475A" Padding="8,6"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="Tenant ID (optional):" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <TextBox x:Name="TenantIdBox" 
                             Background="#313244" Foreground="#CDD6F4"
                             BorderBrush="#45475A" Padding="8,6"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="Leave blank to use default tenant. SSO login will open your browser." 
                               FontSize="11" Foreground="#6C7086" Margin="0,0,0,12" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- OpenAI ChatGPT Settings -->
                <StackPanel x:Name="OpenAiSettingsPanel" Visibility="Collapsed">
                    <TextBlock Text="OpenAI API Key:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="OpenAiApiKeyBox" 
                                 Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" Padding="8,6"
                                 Margin="0,0,0,4"/>
                    <TextBlock Text="Get your API key from platform.openai.com" 
                               FontSize="11" Foreground="#6C7086" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Text="Model:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OpenAiModelBox"
                              Background="#313244" Foreground="#CDD6F4"
                              BorderBrush="#45475A" Padding="8,6"
                              Margin="0,0,0,12"
                              IsEditable="True" Text="gpt-4o">
                        <ComboBoxItem Content="gpt-4o"/>
                        <ComboBoxItem Content="gpt-4o-mini"/>
                        <ComboBoxItem Content="gpt-4-turbo"/>
                        <ComboBoxItem Content="o3-mini"/>
                    </ComboBox>
                </StackPanel>

                <!-- Claude Settings -->
                <StackPanel x:Name="ClaudeSettingsPanel" Visibility="Collapsed">
                    <TextBlock Text="Claude API Key:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ClaudeApiKeyBox" 
                                 Background="#313244" Foreground="#CDD6F4"
                                 BorderBrush="#45475A" Padding="8,6"
                                 Margin="0,0,0,4"/>
                    <TextBlock Text="Get your API key from console.anthropic.com" 
                               FontSize="11" Foreground="#6C7086" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Text="Model:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ClaudeModelBox"
                              Background="#313244" Foreground="#CDD6F4"
                              BorderBrush="#45475A" Padding="8,6"
                              Margin="0,0,0,12"
                              IsEditable="True" Text="claude-sonnet-4-20250514">
                        <ComboBoxItem Content="claude-sonnet-4-20250514"/>
                        <ComboBoxItem Content="claude-opus-4-20250514"/>
                        <ComboBoxItem Content="claude-3-5-haiku-20241022"/>
                    </ComboBox>
                </StackPanel>

                <!-- Ollama Settings -->
                <StackPanel x:Name="OllamaSettingsPanel" Visibility="Collapsed">
                    <TextBlock Text="Ollama Endpoint:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <TextBox x:Name="OllamaEndpointBox" 
                             Background="#313244" Foreground="#CDD6F4"
                             BorderBrush="#45475A" Padding="8,6"
                             Margin="0,0,0,4"
                             Text="http://127.0.0.1:11434"/>
                    <TextBlock Text="Default: http://127.0.0.1:11434. Ensure Ollama is running locally." 
                               FontSize="11" Foreground="#6C7086" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <TextBlock Text="Model:" Foreground="#BAC2DE" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OllamaModelBox"
                              Background="#313244" Foreground="#CDD6F4"
                              BorderBrush="#45475A" Padding="8,6"
                              Margin="0,0,0,12"
                              IsEditable="True" Text="llama3">
                        <ComboBoxItem Content="llama3"/>
                        <ComboBoxItem Content="llama3.1"/>
                        <ComboBoxItem Content="codellama"/>
                        <ComboBoxItem Content="mistral"/>
                        <ComboBoxItem Content="deepseek-coder-v2"/>
                        <ComboBoxItem Content="qwen2.5-coder"/>
                        <ComboBoxItem Content="gemma3"/>
                        <ComboBoxItem Content="gemma4"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" 
                            Style="{StaticResource PrimaryButton}"
                            Background="#45475A" Foreground="#CDD6F4"
                            Margin="0,0,8,0"
                            Click="CancelSettings_Click"/>
                    <Button Content="Save Settings" 
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveSettings_Click"/>
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Chat Messages -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,4,0,4">
            <ItemsControl x:Name="MessagesPanel" Padding="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:ChatBubbleControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading indicator -->
        <Border Grid.Row="2" Padding="8,4"
                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⏳ " FontSize="14"/>
                <TextBlock x:Name="StatusText" Text="Thinking..." 
                           Foreground="#A6E3A1" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#181825" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="InputBox"
                         Style="{StaticResource ChatInput}"
                         KeyDown="InputBox_KeyDown"
                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBool}}">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>

                <Button Grid.Column="1" Content="▶ Send"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBool}}"
                        Click="Send_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
