<Window x:Class="RevCode.UI.CodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="RevCode - C# Code Editor" 
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6C7086"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#181825" Padding="8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="&#x25B6; Run (F5)" 
                            Style="{StaticResource ToolbarButton}"
                            Background="#A6E3A1" Foreground="#1E1E2E"
                            FontWeight="Bold"
                            Click="RunCode_Click"/>
                    <Button Content="Clear Output" 
                            Style="{StaticResource ToolbarButton}"
                            Click="ClearOutput_Click"/>
                    <Button Content="Clear Code" 
                            Style="{StaticResource ToolbarButton}"
                            Click="ClearCode_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="PinButton" Content="&#x1F4CC; Pin" 
                            Style="{StaticResource ToolbarButton}"
                            Click="PinWindow_Click"
                            ToolTip="Keep window on top of other windows"/>
                    <TextBlock Text="RevCode" 
                               Foreground="#6C7086" FontSize="12"
                               VerticalAlignment="Center"
                               Margin="8,0,8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Code Editor with Syntax Highlighting -->
        <Border Grid.Row="1" BorderBrush="#313244" BorderThickness="0,1">
            <avalonEdit:TextEditor x:Name="CodeEditor"
                                   Background="#1E1E2E"
                                   Foreground="#CDD6F4"
                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   Padding="8"
                                   BorderThickness="0"
                                   PreviewKeyDown="CodeEditor_KeyDown"/>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch"
                      Background="#313244" Cursor="SizeNS"/>

        <!-- Output Panel -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#181825" Padding="8,4">
                <TextBlock Text="Output" Foreground="#A6ADC8" FontSize="11" FontWeight="SemiBold"/>
            </Border>
            <TextBox x:Name="OutputBox" Grid.Row="1"
                     Background="#11111B" Foreground="#A6ADC8"
                     BorderThickness="0"
                     FontFamily="Cascadia Code,Consolas,Courier New"
                     FontSize="12"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8"
                     CaretBrush="#F5E0DC"/>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#181825" Padding="8,4">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="Ready" 
                           Foreground="#6C7086" FontSize="11"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="LineColText" Text="" 
                           Foreground="#6C7086" FontSize="11"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
